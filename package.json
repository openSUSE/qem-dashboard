{
  "name": "qem-dashboard",
  "main": "assets/main.js",
  "type": "module",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:clean": "npm run clean && npm run build",
    "watch": "vite build --watch",
    "clean": "rm -fr public/asset/*",
    "lint": "npm run lint:js && npm run lint:md",
    "lint:js": "eslint \"assets/*.js\" \"assets/**/*.js\" \"assets/**/*.vue\" \"t/*.js\" --ignore-pattern assets/webpack.config.d",
    "prettier-help": "prettier --help",
    "lint:md": "prettier --check \"*.md\" \"docs/*.md\"",
    "lint:commit": "gitlint",
    "lint:fix": "npm run tidy:js && npm run tidy:md",
    "tidy:js": "npm run lint:js -- --fix",
    "tidy:md": "prettier --write \"*.md\" \"docs/*.md\"",
    "test:unit": "vitest run",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,vue}": "eslint --fix",
    "*.{pl,pm,t}": "perltidy -b -bext='/'",
    "*.md": "prettier --write"
  },
  "engines": {
    "node": ">= 18",
    "npm": ">= 10.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.2",
    "tshy": {
      "@typescript/native-preview": "npm:typescript@^5.4.0"
    }
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@mojojs/path": "^1.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "bootstrap": "^5.3.8",
    "date-fns": "^4.1.0",
    "pinia": "^3.0.4",
    "swagger-ui-dist": "^5.32.6",
    "vite": "^8.0.14",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@mojojs/core": "^1.26.14",
    "@mojolicious/server-starter": "^2.2.0",
    "@types/node": "^25.9.1",
    "@vue/test-utils": "^2.4.11",
    "eslint": "10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "tap": "^21.7.4",
    "vitest": "^4.1.7"
  }
}
